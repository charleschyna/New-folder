# ─── EchoTutor Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Django
SECRET_KEY=your-super-secret-django-key-here
DEBUG=True

# Database (Neon PostgreSQL)
DB_NAME=echotutor
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-neon-db-host.neon.tech
DB_PORT=5432
DB_SSLMODE=require

# Redis (for Channels / real-time)
REDIS_URL=redis://localhost:6379

# OpenAI (GPT-4o teaching engine)
OPENAI_API_KEY=sk-...

# D-ID (talking avatar generation)
DID_API_KEY=...

# ElevenLabs (premium TTS, optional)
ELEVENLABS_API_KEY=...
